{
  "annotations": {
    "list": []
  },
  "description": "ARIS 4.0 — Distributed Traces via Jaeger/OpenTelemetry",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Trace Search",
      "type": "jaeger",
      "datasource": {
        "type": "jaeger",
        "uid": "jaeger"
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {}
    },
    {
      "title": "Request Duration Heatmap (p50/p95/p99)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=~\"aris-.*\"}[$__rate_interval])) by (le, job))",
          "legendFormat": "p50 — {{job}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=~\"aris-.*\"}[$__rate_interval])) by (le, job))",
          "legendFormat": "p95 — {{job}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=~\"aris-.*\"}[$__rate_interval])) by (le, job))",
          "legendFormat": "p99 — {{job}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "title": "Error Rate by Service",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 3,
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count{job=~\"aris-.*\", status_code=~\"5..\"}[$__rate_interval])) by (job) / sum(rate(http_request_duration_seconds_count{job=~\"aris-.*\"}[$__rate_interval])) by (job) * 100",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "title": "Top 10 Slowest Endpoints (p99)",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 4,
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=~\"aris-.*\"}[$__rate_interval])) by (le, job, method, route)))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "le": true },
            "renameByName": {
              "job": "Service",
              "method": "Method",
              "route": "Endpoint",
              "Value": "p99 (s)"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [{ "field": "p99 (s)", "desc": true }]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99 (s)" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 0.5 },
                    { "color": "red", "value": 2 }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "title": "Request Throughput by Service",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 5,
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count{job=~\"aris-.*\"}[$__rate_interval])) by (job)",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "stacking": { "mode": "normal" }
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "title": "Trace Count by Service (last 1h)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 26 },
      "id": 6,
      "targets": [
        {
          "expr": "sum(increase(http_request_duration_seconds_count{job=~\"aris-.*\"}[1h])) by (job)",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    }
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["aris", "traces", "opentelemetry", "jaeger"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(http_request_duration_seconds_count, job)",
        "name": "service",
        "type": "query",
        "includeAll": true,
        "multi": true,
        "query": "label_values(http_request_duration_seconds_count, job)"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "ARIS Distributed Traces",
  "uid": "aris-distributed-traces",
  "version": 1,
  "weekStart": "monday"
}
