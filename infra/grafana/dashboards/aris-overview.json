          },
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(aris_http_requests_total{status=~\"5..\", service=~\"$service\", group=~\"$group\"}[5m])) by (service)",
          "refId": "A",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 22,
      "title": "Client Error Rate (4xx) by Service",
      "description": "Client-side error rate per service over a 5-minute window. Alert threshold: >20% sustained for 5 minutes (HighClientErrorRate rule).",
