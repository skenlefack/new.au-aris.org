{
  "name": "@aris/kafka-client",
  "version": "0.1.0",
  "private": true,
  "description": "ARIS 4.0 — Generic Kafka producer/consumer with DLQ for NestJS",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./fastify": {
      "types": "./dist/fastify/index.d.ts",
      "default": "./dist/fastify/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "fastify": ["dist/fastify/index.d.ts"]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "fastify-plugin": "^5.0.0",
    "kafkajs": "^2.2.4",
    "uuid": "^9.0.1"
  },
  "peerDependencies": {
    "@aris/shared-types": "workspace:*",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "fastify": "^5.0.0",
    "reflect-metadata": "^0.2.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "reflect-metadata": {
      "optional": true
    },
    "fastify": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aris/shared-types": "workspace:*",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/uuid": "^9.0.0",
    "fastify": "^5.0.0",
    "reflect-metadata": "^0.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
