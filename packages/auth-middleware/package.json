{
  "name": "@aris/auth-middleware",
  "version": "0.1.0",
  "private": true,
  "description": "ARIS 4.0 — JWT RS256 authentication, RBAC guards, tenant isolation",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./fastify": {
      "types": "./dist/fastify/index.d.ts",
      "default": "./dist/fastify/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "fastify": ["dist/fastify/index.d.ts"]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "fastify-plugin": "^5.0.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.0"
  },
  "peerDependencies": {
    "@aris/shared-types": "workspace:*",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "fastify": "^5.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": { "optional": true },
    "@nestjs/core": { "optional": true },
    "reflect-metadata": { "optional": true },
    "rxjs": { "optional": true },
    "fastify": { "optional": true }
  },
  "devDependencies": {
    "@aris/shared-types": "workspace:*",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "fastify": "^5.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.2",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
