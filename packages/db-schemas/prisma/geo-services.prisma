// ARIS 3.0 — Geo Services Schema
// PostGIS spatial queries, risk layers, admin boundaries
//
// NOTE: The `geom` column on admin_boundaries and geo_events
// is a PostGIS geometry type managed via raw SQL ($queryRaw).
// Prisma uses Unsupported("geometry(...)") as a marker;
// actual spatial indexing is created via migration SQL:
//
//   CREATE INDEX idx_admin_boundaries_geom
//     ON geo_services.admin_boundaries USING GIST (geom);
//   CREATE INDEX idx_geo_events_geom
//     ON geo_services.geo_events USING GIST (geom);

enum GeoLayerType {
  BOUNDARY
  RISK
  FACILITY
  CORRIDOR
  HEATMAP

  @@schema("geo_services")
}

model MapLayer {
  id            String       @id @default(uuid()) @db.Uuid
  name          String       @unique @db.VarChar(100)
  description   String?
  layer_type    GeoLayerType
  source_table  String       @db.VarChar(100)
  geometry_type String       @db.VarChar(30) // Point, LineString, Polygon, MultiPolygon
  style         Json         @default("{}")
  min_zoom      Int          @default(0)
  max_zoom      Int          @default(18)
  is_active     Boolean      @default(true)
  sort_order    Int          @default(0)
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  @@index([layer_type])
  @@index([is_active])
  @@map("map_layers")
  @@schema("geo_services")
}

model AdminBoundary {
  id           String                              @id @default(uuid()) @db.Uuid
  code         String                              @unique @db.VarChar(20)
  name         String                              @db.VarChar(255)
  name_en      String                              @db.VarChar(255)
  name_fr      String                              @db.VarChar(255)
  level        String                              @db.VarChar(20) // COUNTRY, ADMIN1, ADMIN2, ADMIN3
  parent_code  String?                             @db.VarChar(20)
  country_code String                              @db.VarChar(3)
  geom         Unsupported("geometry(MultiPolygon, 4326)")?
  centroid_lat Float?
  centroid_lng Float?
  properties   Json                                @default("{}")
  created_at   DateTime                            @default(now())
  updated_at   DateTime                            @updatedAt

  @@index([level])
  @@index([country_code])
  @@index([parent_code])
  @@map("admin_boundaries")
  @@schema("geo_services")
}

/// Spatial index of domain events for risk map aggregation.
/// Populated by Kafka consumers from health/livestock/fisheries events.
model GeoEvent {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_id   String   @db.Uuid
  entity_type String   @db.VarChar(100) // health_event, vaccination, surveillance
  entity_id   String   @db.Uuid
  disease_id  String?  @db.Uuid
  latitude    Float
  longitude   Float
  geom        Unsupported("geometry(Point, 4326)")?
  occurred_at DateTime
  properties  Json     @default("{}")
  created_at  DateTime @default(now())

  @@index([tenant_id])
  @@index([entity_type])
  @@index([disease_id])
  @@index([occurred_at])
  @@map("geo_events")
  @@schema("geo_services")
}
