  name              Json     @db.JsonB
  description       Json?    @db.JsonB
  frameworkCategory String?  @map("framework_category") @db.VarChar(50) // law, regulation, decree, policy, standard, guideline
  scope             String   @default("continental") @db.VarChar(20)
  ownerId           String?  @map("owner_id") @db.Uuid
  ownerType         String   @default("continental") @map("owner_type") @db.VarChar(20)
  isActive          Boolean  @default(true) @map("is_active")
  isDefault         Boolean  @default(false) @map("is_default")
  sortOrder         Int      @default(0) @map("sort_order")
  metadata          Json?    @db.JsonB
  createdBy         String?  @map("created_by") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([code, scope, ownerId], map: "uq_ref_legal_framework_type_code_scope")
  @@index([scope], map: "idx_ref_legal_framework_type_scope")
  @@map("ref_legal_framework_types")
  @@schema("animal_health")
}

// ── Stakeholder Types (Governance) ──

model RefStakeholderType {
  id      String   @id @default(uuid()) @db.Uuid
  code    String   @db.VarChar(50)
  name    Json     @db.JsonB
  description Json? @db.JsonB
  sector  String?  @db.VarChar(50) // public, private, ngo, international, academic, research
