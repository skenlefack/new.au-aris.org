  @@index([isNotifiable], map: "idx_ref_disease_notifiable")
  @@map("ref_diseases")
  @@schema("animal_health")
}

// ── Disease-Species Junction ──

model RefDiseaseSpecies {
  id             String   @id @default(uuid()) @db.Uuid
  diseaseId      String   @map("disease_id") @db.Uuid
  speciesId      String   @map("species_id") @db.Uuid
  susceptibility String?  @db.VarChar(50)
  notes          Json?    @db.JsonB

  disease        RefDisease @relation(fields: [diseaseId], references: [id])
  species        RefSpecies @relation(fields: [speciesId], references: [id])

  @@unique([diseaseId, speciesId], map: "uq_ref_disease_species")
  @@index([diseaseId], map: "idx_ref_disease_species_disease")
  @@index([speciesId], map: "idx_ref_disease_species_species")
  @@map("ref_disease_species")
  @@schema("animal_health")
}

