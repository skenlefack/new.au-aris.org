  description     Json?    @db.JsonB
  oieCode         String?  @map("oie_code") @db.VarChar(50)
  isNotifiable    Boolean  @default(false) @map("is_notifiable")
  isZoonotic      Boolean  @default(false) @map("is_zoonotic")
  category        String?  @db.VarChar(50)
  scope           String   @default("continental") @db.VarChar(20)
  ownerId         String?  @map("owner_id") @db.Uuid
  ownerType       String   @default("continental") @map("owner_type") @db.VarChar(20)
  isActive        Boolean  @default(true) @map("is_active")
  isDefault       Boolean  @default(false) @map("is_default")
  sortOrder       Int      @default(0) @map("sort_order")
  metadata        Json?    @db.JsonB
  createdBy       String?  @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

