// ARIS 3.0 — Collecte Models
// Campaign orchestration, form submissions, offline sync
// + Workflow engine: validation pyramid (admin5→national→REC→continental)

// ── Enums ──

enum CampaignStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED

  @@map("campaign_status")
  @@schema("public")
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  VALIDATING
  VALIDATED
  REJECTED

  @@map("submission_status")
  @@schema("public")
}

enum ConflictStrategy {
  LAST_WRITE_WINS
  MANUAL_MERGE

  @@map("conflict_strategy")
  @@schema("public")
}

enum CollecteInstanceStatus {
  IN_PROGRESS
  COMPLETED
  REJECTED
  RETURNED
  EXPIRED
  CANCELLED

  @@map("collecte_instance_status")
  @@schema("public")
}

enum CollectePriority {
  LOW
  NORMAL
  HIGH
  URGENT
  CRITICAL

  @@map("collecte_priority")
  @@schema("public")
}

enum CollectionCampaignStatus {
  PLANNED
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED

  @@map("collection_campaign_status")
  @@schema("public")
}

enum CampaignAssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  OVERDUE

  @@map("campaign_assignment_status")
  @@schema("public")
}

// ── Campaign (existing) ──

model Campaign {
  id                String         @id @default(uuid()) @db.Uuid
  tenantId          String         @map("tenant_id") @db.Uuid
  name              String         @db.VarChar(255)
  domain            String         @db.VarChar(100)
  templateId        String         @map("template_id") @db.Uuid
  startDate         DateTime       @map("start_date") @db.Date
  endDate           DateTime       @map("end_date") @db.Date
  targetZones       String[]       @map("target_zones") @db.Uuid
  assignedAgents    String[]       @map("assigned_agents") @db.Uuid
  targetSubmissions Int?           @map("target_submissions")
  status            CampaignStatus @default(PLANNED)
  description       String?        @db.Text
  conflictStrategy  ConflictStrategy @default(LAST_WRITE_WINS) @map("conflict_strategy")
  dataContractId    String?        @map("data_contract_id") @db.Uuid
  createdBy         String         @map("created_by") @db.Uuid
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  submissions Submission[]

  @@index([tenantId], map: "idx_campaign_tenant_id")
  @@index([domain], map: "idx_campaign_domain")
  @@index([status], map: "idx_campaign_status")
  @@index([templateId], map: "idx_campaign_template_id")
  @@map("campaigns")
  @@schema("public")
}

// ── Submission (existing) ──

model Submission {
  id                  String           @id @default(uuid()) @db.Uuid
  tenantId            String           @map("tenant_id") @db.Uuid
  campaignId          String           @map("campaign_id") @db.Uuid
  templateId          String           @map("template_id") @db.Uuid
  data                Json
  submittedBy         String           @map("submitted_by") @db.Uuid
  submittedAt         DateTime         @map("submitted_at") @db.Timestamptz
  deviceId            String?          @map("device_id") @db.VarChar(255)
  gpsLat              Float?           @map("gps_lat")
  gpsLng              Float?           @map("gps_lng")
  gpsAccuracy         Float?           @map("gps_accuracy")
  offlineCreatedAt    DateTime?        @map("offline_created_at") @db.Timestamptz
  syncedAt            DateTime?        @map("synced_at") @db.Timestamptz
  qualityReportId     String?          @map("quality_report_id") @db.Uuid
  workflowInstanceId  String?          @map("workflow_instance_id") @db.Uuid
  status              SubmissionStatus @default(SUBMITTED)
  dataClassification  String           @default("RESTRICTED") @map("data_classification") @db.VarChar(20)
  version             Int              @default(1)
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  collecteInstance CollecteInstance?

  @@index([tenantId], map: "idx_submission_tenant_id")
  @@index([campaignId], map: "idx_submission_campaign_id")
  @@index([submittedBy], map: "idx_submission_submitted_by")
  @@index([status], map: "idx_submission_status")
  @@index([offlineCreatedAt], map: "idx_submission_offline_created_at")
  @@map("submissions")
  @@schema("public")
}

// ── Sync Log (tracks offline sync events) ──

model SyncLog {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  deviceId        String?  @map("device_id") @db.VarChar(255)
  syncedAt        DateTime @map("synced_at") @db.Timestamptz
  submissionCount Int      @map("submission_count")
  acceptedCount   Int      @map("accepted_count")
  rejectedCount   Int      @map("rejected_count")
  conflictCount   Int      @map("conflict_count")
  durationMs      Int      @map("duration_ms")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([tenantId], map: "idx_sync_log_tenant_id")
  @@index([userId], map: "idx_sync_log_user_id")
  @@index([syncedAt], map: "idx_sync_log_synced_at")
  @@map("sync_logs")
  @@schema("public")
}

// ══════════════════════════════════════════════════════════════════
// WORKFLOW ENGINE — Validation Pyramid (admin5 → national → REC → continental)
// ══════════════════════════════════════════════════════════════════

// ── Workflow Definition — Per-country validation chain configuration ──

model CollecteWorkflow {
  id                      String   @id @default(uuid()) @db.Uuid
  countryId               String   @unique @map("country_id") @db.Uuid
  name                    Json     // { "en": "Kenya Validation Chain", "fr": "..." }
  description             Json?
  isActive                Boolean  @default(true) @map("is_active")
  startLevel              Int      @default(5) @map("start_level")  // admin level where data entry starts
  endLevel                Int      @default(0) @map("end_level")    // 0=national, -1=REC, -2=continental
  defaultTransmitDelay    Int      @default(72) @map("default_transmit_delay")   // hours
  defaultValidationDelay  Int      @default(48) @map("default_validation_delay") // hours
  autoTransmitEnabled     Boolean  @default(true) @map("auto_transmit_enabled")
  autoValidateEnabled     Boolean  @default(false) @map("auto_validate_enabled")
  requireComment          Boolean  @default(false) @map("require_comment")
  allowReject             Boolean  @default(true) @map("allow_reject")
  allowReturnForCorrection Boolean @default(true) @map("allow_return_for_correction")
  notifyOnSubmit          Boolean  @default(true) @map("notify_on_submit")
  notifyOnValidate        Boolean  @default(true) @map("notify_on_validate")
  notifyOnReject          Boolean  @default(true) @map("notify_on_reject")
  notifyOnAutoTransmit    Boolean  @default(true) @map("notify_on_auto_transmit")
  metadata                Json?
  createdBy               String?  @map("created_by") @db.Uuid
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime @updatedAt @map("updated_at") @db.Timestamptz

  country   Country               @relation(fields: [countryId], references: [id])
  steps     CollecteWorkflowStep[]
  instances CollecteInstance[]

  @@index([isActive], map: "idx_cw_is_active")
  @@map("collecte_workflows")
  @@schema("public")
}

// ── Workflow Step — Specific step in the validation chain ──

model CollecteWorkflowStep {
  id                       String  @id @default(uuid()) @db.Uuid
  workflowId               String  @map("workflow_id") @db.Uuid
  stepOrder                Int     @map("step_order")       // 0 = first (field), N = last
  levelType                String  @map("level_type") @db.VarChar(20) // admin5..admin1, national, regional, continental
  adminLevel               Int?    @map("admin_level")      // 1-5 if levelType is adminX
  name                     Json    // { "en": "Village Collection", "fr": "Collecte Village" }
  description              Json?
  assignmentMode           String  @default("any") @map("assignment_mode") @db.VarChar(20) // any, assigned, role, function
  allowedFunctionIds       Json?   @map("allowed_function_ids")
  canValidate              Boolean @default(true) @map("can_validate")
  canReject                Boolean @default(true) @map("can_reject")
  canReturnForCorrection   Boolean @default(true) @map("can_return_for_correction")
  canEdit                  Boolean @default(false) @map("can_edit")
  canAddComment            Boolean @default(true) @map("can_add_comment")
  canAttachFiles           Boolean @default(true) @map("can_attach_files")
  transmitDelayHours       Int?    @map("transmit_delay_hours")    // null = use workflow default
  validationDelayHours     Int?    @map("validation_delay_hours")
  autoRouteToNext          Boolean @default(true) @map("auto_route_to_next")
  requireChooseValidator   Boolean @default(false) @map("require_choose_validator")
  metadata                 Json?
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime @updatedAt @map("updated_at") @db.Timestamptz

  workflow CollecteWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, stepOrder], map: "uq_cw_step_order")
  @@index([workflowId], map: "idx_cws_workflow_id")
  @@map("collecte_workflow_steps")
  @@schema("public")
}

// ── Validation Chain — Who validates who (user → validator links) ──

model CollecteValidationChain {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  validatorId       String   @map("validator_id") @db.Uuid
  priority          Int      @default(1) // 1=primary, 2=secondary, 3=backup
  levelType         String   @map("level_type") @db.VarChar(20) // validator's level
  isActive          Boolean  @default(true) @map("is_active")
  isAutoAssigned    Boolean  @default(false) @map("is_auto_assigned")
  backupValidatorId String?  @map("backup_validator_id") @db.Uuid
  metadata          Json?
  createdBy         String?  @map("created_by") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user            User  @relation("UserCollecteValidators", fields: [userId], references: [id])
  validator       User  @relation("CollecteValidatorFor", fields: [validatorId], references: [id])
  backupValidator User? @relation("CollecteBackupValidatorFor", fields: [backupValidatorId], references: [id])

  @@unique([userId, validatorId], map: "uq_cvc_user_validator")
  @@index([userId], map: "idx_cvc_user_id")
  @@index([validatorId], map: "idx_cvc_validator_id")
  @@map("collecte_validation_chains")
  @@schema("public")
}

// ── Collecte Instance — Active workflow instance for a submission ──

model CollecteInstance {
  id                String                @id @default(uuid()) @db.Uuid
  workflowId        String                @map("workflow_id") @db.Uuid
  submissionId      String                @unique @map("submission_id") @db.Uuid
  formSubmissionId  String?               @unique @map("form_submission_id") @db.Uuid
  currentStepOrder  Int                   @default(0) @map("current_step_order")
  status            CollecteInstanceStatus @default(IN_PROGRESS)
  submittedBy       String                @map("submitted_by") @db.Uuid
  submittedAt       DateTime              @default(now()) @map("submitted_at") @db.Timestamptz
  completedAt       DateTime?             @map("completed_at") @db.Timestamptz
  currentDeadline   DateTime?             @map("current_deadline") @db.Timestamptz
  isOverdue         Boolean               @default(false) @map("is_overdue")
  currentAssigneeId String?               @map("current_assignee_id") @db.Uuid
  priority          CollectePriority      @default(NORMAL)
  metadata          Json?
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime              @updatedAt @map("updated_at") @db.Timestamptz

  workflow    CollecteWorkflow  @relation(fields: [workflowId], references: [id])
  submission  Submission        @relation(fields: [submissionId], references: [id])
  formSubmission FormSubmission? @relation(fields: [formSubmissionId], references: [id])
  history     CollecteHistory[]

  @@index([workflowId], map: "idx_ci_workflow_id")
  @@index([status, currentAssigneeId], map: "idx_ci_status_assignee")
  @@index([status, currentDeadline], map: "idx_ci_status_deadline")
  @@index([submittedBy], map: "idx_ci_submitted_by")
  @@map("collecte_instances")
  @@schema("public")
}

// ── Collecte History — Complete audit trail ──

model CollecteHistory {
  id              String    @id @default(uuid()) @db.Uuid
  instanceId      String    @map("instance_id") @db.Uuid
  action          String    @db.VarChar(30) // submitted, validated, rejected, returned, auto_transmitted, auto_validated, reassigned, commented, escalated
  fromStep        Int?      @map("from_step")
  toStep          Int?      @map("to_step")
  performedBy     String?   @map("performed_by") @db.Uuid
  performedByName String?   @map("performed_by_name") @db.VarChar(200)
  performedAt     DateTime  @default(now()) @map("performed_at") @db.Timestamptz
  comment         Json?     // multilingue or free text
  reason          String?   @db.Text
  attachments     Json?     // array of file refs
  fromAssignee    String?   @map("from_assignee") @db.Uuid
  toAssignee      String?   @map("to_assignee") @db.Uuid
  isAutomatic     Boolean   @default(false) @map("is_automatic")
  dataSnapshot    Json?     @map("data_snapshot")
  metadata        Json?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  instance CollecteInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId, createdAt], map: "idx_ch_instance_created")
  @@index([performedBy], map: "idx_ch_performed_by")
  @@map("collecte_history")
  @@schema("public")
}

// ── Collection Campaign — Enhanced campaign model for collecte workflow ──

model CollectionCampaign {
  id                  String                   @id @default(uuid()) @db.Uuid
  code                String                   @db.VarChar(100)
  name                Json                     // { "en": "Q1 2025 Surveillance", "fr": "..." }
  description         Json?
  domain              String                   @db.VarChar(50)
  formTemplateId      String                   @map("form_template_id") @db.Uuid
  startDate           DateTime                 @map("start_date") @db.Date
  endDate             DateTime                 @map("end_date") @db.Date
  targetCountries     Json?                    @map("target_countries")   // ["KE", "TZ"]
  targetRecIds        Json?                    @map("target_rec_ids")
  targetAdminAreas    Json?                    @map("target_admin_areas")
  targetSubmissions   Int?                     @map("target_submissions")
  targetPerAgent      Int?                     @map("target_per_agent")
  frequency           String?                  @db.VarChar(20) // one_time, daily, weekly, biweekly, monthly, quarterly
  status              CollectionCampaignStatus @default(PLANNED)
  scope               String                   @default("continental") @db.VarChar(20)
  ownerId             String?                  @map("owner_id") @db.Uuid
  ownerType           String                   @default("continental") @map("owner_type") @db.VarChar(20)
  sendReminders       Boolean                  @default(true) @map("send_reminders")
  reminderDaysBefore  Int                      @default(3) @map("reminder_days_before")
  metadata            Json?
  createdBy           String?                  @map("created_by") @db.Uuid
  createdAt           DateTime                 @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime                 @updatedAt @map("updated_at") @db.Timestamptz

  formTemplate FormTemplate       @relation(fields: [formTemplateId], references: [id])
  assignments  CampaignAssignment[]

  @@unique([code, scope, ownerId], map: "uq_cc_code_scope_owner")
  @@index([status], map: "idx_cc_status")
  @@index([domain], map: "idx_cc_domain")
  @@index([formTemplateId], map: "idx_cc_template_id")
  @@map("collection_campaigns")
  @@schema("public")
}

// ── Campaign Assignment — Agent assignment to campaign ──

model CampaignAssignment {
  id                    String                   @id @default(uuid()) @db.Uuid
  campaignId            String                   @map("campaign_id") @db.Uuid
  userId                String                   @map("user_id") @db.Uuid
  countryCode           String?                  @map("country_code") @db.VarChar(2)
  adminLevel1           String?                  @map("admin_level_1") @db.VarChar(100)
  adminLevel2           String?                  @map("admin_level_2") @db.VarChar(100)
  adminLevel3           String?                  @map("admin_level_3") @db.VarChar(100)
  adminLevel4           String?                  @map("admin_level_4") @db.VarChar(100)
  adminLevel5           String?                  @map("admin_level_5") @db.VarChar(100)
  targetSubmissions     Int?                     @map("target_submissions")
  completedSubmissions  Int                      @default(0) @map("completed_submissions")
  status                CampaignAssignmentStatus @default(ASSIGNED)
  assignedAt            DateTime                 @default(now()) @map("assigned_at") @db.Timestamptz
  startedAt             DateTime?                @map("started_at") @db.Timestamptz
  completedAt           DateTime?                @map("completed_at") @db.Timestamptz
  dueDate               DateTime?                @map("due_date") @db.Timestamptz
  metadata              Json?
  createdAt             DateTime                 @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime                 @updatedAt @map("updated_at") @db.Timestamptz

  campaign CollectionCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User               @relation(fields: [userId], references: [id])

  @@unique([campaignId, userId], map: "uq_ca_campaign_user")
  @@index([campaignId], map: "idx_ca_campaign_id")
  @@index([userId], map: "idx_ca_user_id")
  @@index([status], map: "idx_ca_status")
  @@map("campaign_assignments")
  @@schema("public")
}
