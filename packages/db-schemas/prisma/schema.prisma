// ARIS 3.0 — Shared Prisma Configuration
// Generator + Datasource only. Models are in separate .prisma files.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["prismaSchemaFolder", "multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "form_builder", "data_contract", "workflow", "geo_services", "animal_health", "knowledge_hub", "interop_hub"]
}
