// ARIS 4.0 — Shared Prisma Configuration
// Generator + Datasource only. Models are in separate .prisma files.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["prismaSchemaFolder", "multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
  schemas   = ["public", "datalake", "form_builder", "data_contract", "workflow", "geo_services", "animal_health", "livestock_prod", "fisheries", "wildlife", "apiculture", "trade_sps", "governance", "climate_env", "knowledge_hub", "interop_hub", "interop_v2", "offline", "support", "analytics"]
}
