// ARIS 3.0 — Tenant Model
// Multi-tenant hierarchy: AU-IBAR → RECs → Member States

enum TenantLevel {
  CONTINENTAL
  REC
  MEMBER_STATE

  @@map("tenant_level")
  @@schema("public")
}

model Tenant {
  id          String      @id @default(uuid()) @db.Uuid
  name        String      @db.VarChar(255)
  code        String      @unique @db.VarChar(20)
  level       TenantLevel
  parentId    String?     @map("parent_id") @db.Uuid
  countryCode String?     @map("country_code") @db.VarChar(2)
  recCode     String?     @map("rec_code") @db.VarChar(20)
  domain      String      @unique @db.VarChar(100)
  config      Json        @default("{}")
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  parent    Tenant?    @relation("TenantHierarchy", fields: [parentId], references: [id])
  children  Tenant[]   @relation("TenantHierarchy")
  users     User[]
  countries Country[]

  @@index([parentId], map: "idx_tenant_parent_id")
  @@index([level], map: "idx_tenant_level")
  @@index([countryCode], map: "idx_tenant_country_code")
  @@index([isActive], map: "idx_tenant_is_active")
  @@map("tenants")
  @@schema("public")
}
