{
  "name": "@aris/db-schemas",
  "version": "0.1.0",
  "private": true,
  "description": "ARIS 4.0 — Prisma schemas and migrations (one schema per service)",
  "scripts": {
    "generate": "cd ../.. && npx prisma generate --schema=packages/db-schemas/prisma",
    "migrate:dev": "cd ../.. && npx prisma migrate dev --schema=packages/db-schemas/prisma",
    "migrate:deploy": "cd ../.. && npx prisma migrate deploy --schema=packages/db-schemas/prisma",
    "migrate:reset": "cd ../.. && npx prisma migrate reset --schema=packages/db-schemas/prisma --force",
    "db:push": "cd ../.. && npx prisma db push --schema=packages/db-schemas/prisma --skip-generate",
    "db:seed": "tsx prisma/seed-tenant.ts && tsx prisma/seed-credential.ts",
    "db:seed:settings": "tsx prisma/seed-settings.ts",
    "db:seed:functions": "tsx prisma/seed-functions.ts",
    "db:seed:all": "tsx prisma/seed-tenant.ts && tsx prisma/seed-credential.ts && tsx prisma/seed-settings.ts && tsx prisma/seed-functions.ts",
    "studio": "cd ../.. && npx prisma studio --schema=packages/db-schemas/prisma",
    "build": "echo 'db-schemas: generate only'",
    "clean": "rm -rf node_modules/.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "bcrypt": "^5.1.1",
    "dotenv": "^17.3.1",
    "prisma": "^6.19.2",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0"
  }
}
