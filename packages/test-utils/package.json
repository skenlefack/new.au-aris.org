{
  "name": "@aris/test-utils",
  "version": "0.1.0",
  "private": true,
  "description": "ARIS 4.0 — Test factories, Testcontainers helpers",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aris/shared-types": "workspace:*",
    "testcontainers": "^10.9.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@prisma/client": "^6.19.2",
    "ioredis": "^5.4.0",
    "vitest": "^1.6.1"
  }
}
