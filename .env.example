# ARIS 4.0 — Environment Configuration
# Copy to .env and customize

# ═══════════════════════════════════════════
# GENERAL
# ═══════════════════════════════════════════
NODE_ENV=development
LOG_LEVEL=debug

# ═══════════════════════════════════════════
# POSTGRESQL + POSTGIS
# ═══════════════════════════════════════════
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=aris
POSTGRES_PASSWORD=aris_dev_2024
POSTGRES_DB=aris

# ═══════════════════════════════════════════
# PGBOUNCER — Connection Pooling
# ═══════════════════════════════════════════
PGBOUNCER_PORT=6432
# Application connections go through PgBouncer (transaction pooling)
DATABASE_URL=postgresql://aris:aris_dev_2024@localhost:6432/aris?pgbouncer=true
# Direct connection for Prisma migrations and introspection (bypasses PgBouncer)
DIRECT_DATABASE_URL=postgresql://aris:aris_dev_2024@localhost:5432/aris

# ═══════════════════════════════════════════
# KAFKA
# ═══════════════════════════════════════════
KAFKA_BROKERS=localhost:9092,localhost:9094,localhost:9096
KAFKA_CLIENT_ID=aris-dev
SCHEMA_REGISTRY_URL=http://localhost:8081

# ═══════════════════════════════════════════
# REDIS
# ═══════════════════════════════════════════
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════════
# OPENSEARCH
# ═══════════════════════════════════════════
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=ArisSearch2024!

# ═══════════════════════════════════════════
# MINIO (S3)
# ═══════════════════════════════════════════
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=aris_minio
MINIO_ROOT_PASSWORD=aris_minio_2024
MINIO_BUCKET=aris-documents

# ═══════════════════════════════════════════
# EMAIL — Provider: smtp (default) | postmark
# ═══════════════════════════════════════════
EMAIL_PROVIDER=smtp

# SMTP (Mailpit dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@au-aris.org

# Postmark (if EMAIL_PROVIDER=postmark)
# POSTMARK_SERVER_TOKEN=your-server-api-token
# POSTMARK_FROM=noreply@au-aris.org
# POSTMARK_MESSAGE_STREAM=outbound
# POSTMARK_TAG=aris

# ═══════════════════════════════════════════
# JWT AUTH
# ═══════════════════════════════════════════
JWT_ALGORITHM=RS256
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
# Generate keys: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# ═══════════════════════════════════════════
# SERVICE PORTS
# ═══════════════════════════════════════════
TENANT_PORT=3001
CREDENTIAL_PORT=3002
MASTER_DATA_PORT=3003
DATA_QUALITY_PORT=3004
DATA_CONTRACT_PORT=3005
MESSAGE_PORT=3006
DRIVE_PORT=3007
REALTIME_PORT=3008
FORM_BUILDER_PORT=3010
COLLECTE_PORT=3011
WORKFLOW_PORT=3012
ANIMAL_HEALTH_PORT=3020
LIVESTOCK_PROD_PORT=3021
FISHERIES_PORT=3022
WILDLIFE_PORT=3023
APICULTURE_PORT=3024
TRADE_SPS_PORT=3025
GOVERNANCE_PORT=3026
CLIMATE_ENV_PORT=3027
ANALYTICS_PORT=3030
GEO_SERVICES_PORT=3031
INTEROP_HUB_PORT=3032
KNOWLEDGE_HUB_PORT=3033
SUPPORT_PORT=3041
INTEROP_PORT=3042
ANALYTICS_WORKER_PORT=3043
DATALAKE_PORT=3044
OFFLINE_PORT=3045

# ═══════════════════════════════════════════
# OPENTELEMETRY — Distributed Tracing
# ═══════════════════════════════════════════
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http
OTEL_ENVIRONMENT=development
# Set to 'true' to completely disable OTel tracing
# OTEL_TRACING_DISABLED=false
# Sampling ratio 0.0–1.0 (1.0 = trace everything, 0.1 = 10% sampling)
# OTEL_TRACES_SAMPLER_ARG=1.0
# Set to 'debug' for verbose OTel SDK logging
# OTEL_LOG_LEVEL=info

# ═══════════════════════════════════════════
# BI TOOLS
# ═══════════════════════════════════════════
SUPERSET_PORT=8088
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=ArisSuperset2024!
METABASE_PORT=3035
METABASE_EMBEDDING_SECRET=aris-metabase-embedding-secret-key-2024-change-in-prod
GRAFANA_PORT=3200
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=aris_grafana_2024

# BI Tools Internal URLs (backend → Docker services)
SUPERSET_INTERNAL_URL=http://superset:8088
METABASE_INTERNAL_URL=http://metabase:3000
GRAFANA_INTERNAL_URL=http://grafana:3000

# Metabase Admin (for auto-setup + session API)
METABASE_ADMIN_EMAIL=admin@au-aris.org
METABASE_ADMIN_PASSWORD=ArisMetabase2024!
