# ARIS 3.0 — Environment Configuration
# Copy to .env and customize

# ═══════════════════════════════════════════
# GENERAL
# ═══════════════════════════════════════════
NODE_ENV=development
LOG_LEVEL=debug

# ═══════════════════════════════════════════
# POSTGRESQL + POSTGIS
# ═══════════════════════════════════════════
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=aris
POSTGRES_PASSWORD=aris_dev_2024
POSTGRES_DB=aris
DATABASE_URL=postgresql://aris:aris_dev_2024@localhost:5432/aris

# ═══════════════════════════════════════════
# KAFKA
# ═══════════════════════════════════════════
KAFKA_BROKERS=localhost:9092,localhost:9094,localhost:9096
KAFKA_CLIENT_ID=aris-dev
SCHEMA_REGISTRY_URL=http://localhost:8081

# ═══════════════════════════════════════════
# REDIS
# ═══════════════════════════════════════════
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════════
# ELASTICSEARCH
# ═══════════════════════════════════════════
ELASTICSEARCH_URL=http://localhost:9200

# ═══════════════════════════════════════════
# MINIO (S3)
# ═══════════════════════════════════════════
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=aris_minio
MINIO_ROOT_PASSWORD=aris_minio_2024
MINIO_BUCKET=aris-documents

# ═══════════════════════════════════════════
# EMAIL (Mailpit dev)
# ═══════════════════════════════════════════
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@aris.africa

# ═══════════════════════════════════════════
# JWT AUTH
# ═══════════════════════════════════════════
JWT_ALGORITHM=RS256
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
# Generate keys: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# ═══════════════════════════════════════════
# SERVICE PORTS
# ═══════════════════════════════════════════
TENANT_PORT=3001
CREDENTIAL_PORT=3002
MASTER_DATA_PORT=3003
DATA_QUALITY_PORT=3004
DATA_CONTRACT_PORT=3005
MESSAGE_PORT=3006
DRIVE_PORT=3007
REALTIME_PORT=3008
FORM_BUILDER_PORT=3010
COLLECTE_PORT=3011
WORKFLOW_PORT=3012
ANIMAL_HEALTH_PORT=3020
LIVESTOCK_PROD_PORT=3021
FISHERIES_PORT=3022
WILDLIFE_PORT=3023
APICULTURE_PORT=3024
TRADE_SPS_PORT=3025
GOVERNANCE_PORT=3026
CLIMATE_ENV_PORT=3027
ANALYTICS_PORT=3030
GEO_SERVICES_PORT=3031
INTEROP_HUB_PORT=3032
KNOWLEDGE_HUB_PORT=3033
