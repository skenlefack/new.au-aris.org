{
  "name": "@aris/master-data-service",
  "version": "0.1.0",
  "private": true,
  "description": "ARIS 4.0 — Master Data service: common dictionary & referentials (geo, species, diseases, units, temporality, identifiers, denominators)",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:migrate": "prisma migrate dev --schema=../../packages/db-schemas/prisma/schema.prisma",
    "db:seed": "tsx src/seed/run-seed.ts"
  },
  "dependencies": {
    "@aris/auth-middleware": "workspace:*",
    "@aris/cache": "workspace:*",
    "@aris/kafka-client": "workspace:*",
    "@aris/shared-types": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@prisma/client": "^6.2.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.2.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "prisma": "^6.2.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
