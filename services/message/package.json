{
  "name": "@aris/message-service",
  "version": "0.1.0",
  "private": true,
  "description": "ARIS 4.0 — Message service: multi-channel notifications (Email, SMS, Push, In-App)",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc --build && npm run copy-templates",
    "copy-templates": "cp -r src/templates/layouts dist/templates/layouts && cp -r src/templates/email dist/templates/email",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@aris/shared-types": "workspace:*",
    "@aris/kafka-client": "workspace:*",
    "@aris/auth-middleware": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@prisma/client": "^6.2.0",
    "@sinclair/typebox": "^0.32.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.0",
    "handlebars": "^4.7.8",
    "node-cron": "^3.0.0",
    "nodemailer": "^6.9.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.0",
    "@types/nodemailer": "^6.4.0",
    "prisma": "^6.2.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
