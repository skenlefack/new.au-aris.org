<!-- welcome.hbs — Email body for new user welcome notifications -->
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
  <tr>
    <td style="padding-bottom: 20px;">
      <p style="margin: 0 0 16px 0; font-family: Arial, Helvetica, sans-serif; font-size: 20px; color: #003366; font-weight: bold;">
        Welcome to ARIS, {{userName}}!
      </p>
      <p style="margin: 0 0 20px 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #333333;">
        Your account has been created with the role <strong>{{roleName}}</strong>.
      </p>

      <!-- Account Details Box -->
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-bottom: 24px; border-collapse: collapse; border: 1px solid #d0d7de; border-radius: 6px;">
        <tr>
          <td colspan="2" style="background-color: #003366; padding: 12px 16px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; font-weight: bold; color: #ffffff; border-bottom: 2px solid #D4AF37;">
            Account Details
          </td>
        </tr>
        <tr>
          <td style="padding: 10px 16px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; font-weight: bold; color: #555555; border-bottom: 1px solid #e0e0e0; width: 35%; background-color: #f8f9fa;">
            Email
          </td>
          <td style="padding: 10px 16px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333; border-bottom: 1px solid #e0e0e0; background-color: #ffffff;">
            {{email}}
          </td>
        </tr>
        <tr>
          <td style="padding: 10px 16px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; font-weight: bold; color: #555555; border-bottom: 1px solid #e0e0e0; background-color: #f8f9fa;">
            Role
          </td>
          <td style="padding: 10px 16px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333; border-bottom: 1px solid #e0e0e0; background-color: #ffffff;">
            {{roleName}}
          </td>
        </tr>
        <tr>
          <td style="padding: 10px 16px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; font-weight: bold; color: #555555; background-color: #f8f9fa;">
            Organization
          </td>
          <td style="padding: 10px 16px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333; background-color: #ffffff;">
            {{tenantName}}
          </td>
        </tr>
      </table>

      <!-- Getting Started -->
      <p style="margin: 0 0 12px 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #003366; font-weight: bold;">
        Getting Started
      </p>
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-bottom: 24px;">
        <tr>
          <td style="padding: 6px 0; font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333;">
            <strong>1.</strong> Log in to the ARIS platform using your email and temporary password.
          </td>
        </tr>
        <tr>
          <td style="padding: 6px 0; font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333;">
            <strong>2.</strong> Change your password and set up multi-factor authentication (MFA).
          </td>
        </tr>
        <tr>
          <td style="padding: 6px 0; font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333;">
            <strong>3.</strong> Review your assigned data collection campaigns and pending tasks.
          </td>
        </tr>
        <tr>
          <td style="padding: 6px 0; font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333;">
            <strong>4.</strong> Explore the ARIS Knowledge Hub for training materials and guides.
          </td>
        </tr>
      </table>

      <!-- CTA Button -->
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin: 24px 0;">
        <tr>
          <td style="border-radius: 6px; background-color: #003366;">
            <a href="{{loginUrl}}" target="_blank" style="display: inline-block; padding: 14px 32px; font-family: Arial, Helvetica, sans-serif; font-size: 16px; font-weight: bold; color: #ffffff; text-decoration: none; border-radius: 6px;">
              Login to ARIS
            </a>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
