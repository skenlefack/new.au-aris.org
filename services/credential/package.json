{
  "name": "@aris/credential-service",
  "version": "0.1.0",
  "private": true,
  "description": "ARIS 3.0 — Credential service: JWT RS256 auth, RBAC, user management",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@aris/auth-middleware": "workspace:*",
    "@aris/i18n": "workspace:*",
    "@aris/kafka-client": "workspace:*",
    "@aris/shared-types": "workspace:*",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@prisma/client": "^5.14.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.0",
    "otpauth": "^9.5.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^9.0.0",
    "prisma": "^5.14.0",
    "testcontainers": "^10.9.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
