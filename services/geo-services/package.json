{
  "name": "@aris/geo-services-service",
  "version": "0.2.0",
  "private": true,
  "description": "ARIS 4.0 — Geo services (Fastify): PostGIS spatial queries, risk layers, admin boundaries",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aris/auth-middleware": "workspace:*",
    "@aris/kafka-client": "workspace:*",
    "@aris/shared-types": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@prisma/client": "^6.2.0",
    "@sinclair/typebox": "^0.34.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.0",
    "ioredis": "^5.4.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "prisma": "^6.2.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
