{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "incremental": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.ts",
    "src/main.ts",
    "src/prisma.service.ts",
    "src/app.module.ts",
    "src/seed.ts",
    "src/compliance/compliance.module.ts",
    "src/compliance/compliance.consumer.ts",
    "src/compliance/compliance.service.ts",
    "src/contract/contract.service.ts",
    "src/contract/contract.controller.ts",
    "src/contract/contract.module.ts",
    "src/contract/dto"
  ]
}
