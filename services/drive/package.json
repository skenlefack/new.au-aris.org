{
  "name": "@aris/drive-service",
  "version": "0.1.0",
  "private": true,
  "description": "ARIS 4.0 — Drive service: document storage (MinIO S3)",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@aris/shared-types": "workspace:*",
    "@aris/kafka-client": "workspace:*",
    "@aris/auth-middleware": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/multipart": "^9.0.0",
    "@prisma/client": "^6.2.0",
    "@sinclair/typebox": "^0.32.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.0",
    "minio": "^8.0.0",
    "pino-pretty": "^13.0.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "prisma": "^6.2.0",
    "testcontainers": "^10.9.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
