{
  "name": "@aris/form-builder-service",
  "version": "0.1.0",
  "private": true,
  "description": "ARIS 4.0 — Form Builder service: JSON Schema-based no-code form templates",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@aris/auth-middleware": "workspace:*",
    "@aris/kafka-client": "workspace:*",
    "@aris/shared-types": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/multipart": "^9.4.0",
    "@prisma/client": "^6.19.2",
    "@sinclair/typebox": "^0.34.0",
    "ajv": "^8.12.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/uuid": "^9.0.0",
    "prisma": "^6.19.2",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
