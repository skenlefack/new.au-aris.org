# ═══════════════════════════════════════════════════════════════
# ARIS 4.0 — Production Environment Configuration
# AU-IBAR Nairobi Data Centre — 4 VMs
# ═══════════════════════════════════════════════════════════════
# VM-DB:    10.202.101.185 (nbo-dbms03)  — PostgreSQL + PgBouncer
# VM-KAFKA: 10.202.101.184 (nbo-brk01)   — Kafka KRaft cluster
# VM-CACHE: 10.202.101.186 (nbo-cch01)   — Redis + OpenSearch
# VM-APP:   10.202.101.183 (nbo-aris04)  — Services + Frontend
# ═══════════════════════════════════════════════════════════════

NODE_ENV=production
LOG_LEVEL=info

# ═══════════════════════════════════════════
# POSTGRESQL + POSTGIS — VM-DB
# ═══════════════════════════════════════════
POSTGRES_HOST=10.202.101.185
POSTGRES_PORT=5432
POSTGRES_USER=aris
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_DB=aris

# ═══════════════════════════════════════════
# PGBOUNCER — Connection Pooling (VM-DB)
# ═══════════════════════════════════════════
PGBOUNCER_PORT=6432
DATABASE_URL=postgresql://aris:__CHANGE_ME__@10.202.101.185:6432/aris?pgbouncer=true
DIRECT_DATABASE_URL=postgresql://aris:__CHANGE_ME__@10.202.101.185:5432/aris

# ═══════════════════════════════════════════
# KAFKA — VM-KAFKA
# ═══════════════════════════════════════════
KAFKA_BROKERS=10.202.101.184:9092,10.202.101.184:9094,10.202.101.184:9096
KAFKA_CLIENT_ID=aris-production
SCHEMA_REGISTRY_URL=http://10.202.101.184:8081

# ═══════════════════════════════════════════
# REDIS — VM-CACHE
# ═══════════════════════════════════════════
REDIS_HOST=10.202.101.186
REDIS_PORT=6379
REDIS_PASSWORD=__CHANGE_ME__
REDIS_URL=redis://:__CHANGE_ME__@10.202.101.186:6379

# ═══════════════════════════════════════════
# OPENSEARCH — VM-CACHE
# ═══════════════════════════════════════════
OPENSEARCH_URL=http://10.202.101.186:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=__CHANGE_ME__

# ═══════════════════════════════════════════
# MINIO (S3) — VM-APP (local)
# ═══════════════════════════════════════════
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=aris_minio_prod
MINIO_ROOT_PASSWORD=__CHANGE_ME__
MINIO_BUCKET=aris-documents

# ═══════════════════════════════════════════
# EMAIL — Provider: postmark
# ═══════════════════════════════════════════
EMAIL_PROVIDER=postmark
POSTMARK_SERVER_TOKEN=__CHANGE_ME__
POSTMARK_FROM=noreply@au-aris.org
POSTMARK_MESSAGE_STREAM=outbound
POSTMARK_TAG=aris

# SMTP fallback (set EMAIL_PROVIDER=smtp to use)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@au-aris.org

# ═══════════════════════════════════════════
# JWT AUTH — RS256 key pair (generated on VM-APP)
# ═══════════════════════════════════════════
JWT_ALGORITHM=RS256
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_PRIVATE_KEY_PATH=/app/keys/private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/public.pem

# ═══════════════════════════════════════════
# SERVICE PORTS
# ═══════════════════════════════════════════
TENANT_PORT=3001
CREDENTIAL_PORT=3002
MASTER_DATA_PORT=3003
DATA_QUALITY_PORT=3004
DATA_CONTRACT_PORT=3005
MESSAGE_PORT=3006
DRIVE_PORT=3007
REALTIME_PORT=3008
FORM_BUILDER_PORT=3010
COLLECTE_PORT=3011
WORKFLOW_PORT=3012
ANIMAL_HEALTH_PORT=3020
LIVESTOCK_PROD_PORT=3021
FISHERIES_PORT=3022
WILDLIFE_PORT=3023
APICULTURE_PORT=3024
TRADE_SPS_PORT=3025
GOVERNANCE_PORT=3026
CLIMATE_ENV_PORT=3027
ANALYTICS_PORT=3030
GEO_SERVICES_PORT=3031
INTEROP_HUB_PORT=3032
KNOWLEDGE_HUB_PORT=3033
SUPPORT_PORT=3041
INTEROP_PORT=3042
ANALYTICS_WORKER_PORT=3043
DATALAKE_PORT=3044
OFFLINE_PORT=3045

# ═══════════════════════════════════════════
# OPENTELEMETRY — Distributed Tracing
# ═══════════════════════════════════════════
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http
OTEL_ENVIRONMENT=production
OTEL_TRACES_SAMPLER_ARG=0.1

# ═══════════════════════════════════════════
# BI TOOLS
# ═══════════════════════════════════════════
SUPERSET_PORT=8088
SUPERSET_SECRET_KEY=__CHANGE_ME__
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=__CHANGE_ME__
METABASE_PORT=3035
METABASE_EMBEDDING_SECRET=__CHANGE_ME__
METABASE_ADMIN_EMAIL=admin@au-aris.org
METABASE_ADMIN_PASSWORD=__CHANGE_ME__
GRAFANA_PORT=3200
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=__CHANGE_ME__

# BI Tools Internal URLs (docker-compose service names)
SUPERSET_INTERNAL_URL=http://superset:8088
METABASE_INTERNAL_URL=http://metabase:3000
GRAFANA_INTERNAL_URL=http://grafana:3000

# ═══════════════════════════════════════════
# BI READ-ONLY USER
# ═══════════════════════════════════════════
BI_READER_PASSWORD=__CHANGE_ME__
