# ARIS 4.0 — Dockerfile for Next.js web app (full monorepo build)
# Usage: docker build -f Dockerfile.web --build-arg APP=web -t aris-web .

# ═══════════════════════════════════════════════
# Stage 1: Base
# ═══════════════════════════════════════════════
FROM node:22-alpine AS base

RUN corepack enable && corepack prepare pnpm@9 --activate
RUN apk add --no-cache libc6-compat

ENV PNPM_HOME="/root/.local/share/pnpm"
ENV PATH="$PNPM_HOME:$PATH"

WORKDIR /app

# ═══════════════════════════════════════════════
# Stage 2: Install & Build
# ═══════════════════════════════════════════════
FROM base AS installer

# Copy full monorepo (filtered by .dockerignore)
COPY . .

# Install all workspace dependencies
RUN pnpm install --frozen-lockfile

# Generate Prisma client (needed by some shared packages)
RUN if [ -d packages/db-schemas/prisma ]; then \
      cd packages/db-schemas && npx prisma generate --schema=prisma 2>/dev/null || true; \
    fi

ENV NEXT_TELEMETRY_DISABLED=1

# NEXT_PUBLIC_* vars must be present at build time (inlined by Next.js)
ARG NEXT_PUBLIC_API_URL=http://localhost
ARG NEXT_PUBLIC_WS_URL=ws://localhost
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV NEXT_PUBLIC_WS_URL=${NEXT_PUBLIC_WS_URL}

# Build all packages + the web app
ARG APP=web
RUN pnpm turbo build --filter='./packages/*' --filter=@aris/${APP}

# ═══════════════════════════════════════════════
# Stage 3: Runner (standalone Next.js output)
# ═══════════════════════════════════════════════
FROM node:22-alpine AS runner

RUN addgroup --system --gid 1001 aris && \
    adduser --system --uid 1001 aris

WORKDIR /app

ARG APP=web

COPY --from=installer --chown=aris:aris /app/apps/${APP}/.next/standalone ./
COPY --from=installer --chown=aris:aris /app/apps/${APP}/.next/static ./apps/${APP}/.next/static
COPY --from=installer --chown=aris:aris /app/apps/${APP}/public ./apps/${APP}/public

USER aris

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ENV APP_NAME=${APP}

EXPOSE 3000

CMD ["sh", "-c", "node apps/${APP_NAME}/server.js"]
